# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/bangladesh-law

# Anthropic Claude API (default QA engine)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Custom Model Integration (Your Colab Model)
# Set this to your ngrok/deployed URL when running from Colab
CUSTOM_MODEL_URL=
# e.g. CUSTOM_MODEL_URL=https://your-ngrok-url.ngrok.io

# Set to 'custom' to use your Colab model, 'claude' to use Claude API
ACTIVE_MODEL=claude

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
